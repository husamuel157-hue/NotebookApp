<?xml version="1.0" encoding="UTF-8" ?>
<Shell
    x:Class="NotebookApp.AppShell"
    xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
    xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
    xmlns:local="clr-namespace:NotebookApp"
    Title="NotebookApp">

    <!-- Bottom Navigation Bar -->
    <TabBar>
        <!-- Home Tab -->
        <Tab Title="Home" Icon="home.png">
            <!-- Optional: Add icon, need to put image in Resources/Images directory -->
            <ShellContent ContentTemplate="{DataTemplate local:MainPage}" Route="MainPage"/>
        </Tab>

        <!-- Task Configuration Tab -->
        <Tab Title="Task Config" Icon="settings.png">
            <!-- Optional: Add icon -->
            <ShellContent ContentTemplate="{DataTemplate local:TaskConfigPage}" Route="TaskConfigPage"/>
        </Tab>
    </TabBar>

</Shell>