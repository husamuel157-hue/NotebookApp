<?xml version="1.0" encoding="utf-8" ?>
<Shell
    x:Class="NotebookApp.AppShell"
    xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
    xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
    xmlns:local="clr-namespace:NotebookApp"
    Title="NotebookApp"
    Shell.TabBarBackgroundColor="#FFFFFF"
    Shell.TabBarTitleColor="#2196F3"
    Shell.TabBarUnselectedColor="#757575"
    Shell.TabBarForegroundColor="#2196F3">

    <!-- Bottom Navigation Bar -->
    <TabBar>
        <!-- Home Tab -->
        <Tab Title="Home"
              Icon="home.png">
            <ShellContent ContentTemplate="{DataTemplate local:MainPage}" 
                         Route="MainPage"/>
        </Tab>

        <!-- Task Preview Tab -->
        <Tab Title="Preview"
              Icon="preview.png">
            <ShellContent ContentTemplate="{DataTemplate local:WeeklyTaskPreviewPage}" 
                         Route="WeeklyTaskPreviewPage"/>
        </Tab>

        <!-- Task Configuration Tab -->
        <Tab Title="Config"
              Icon="settings.png">
            <ShellContent ContentTemplate="{DataTemplate local:TaskConfigPage}" 
                         Route="TaskConfigPage"/>
        </Tab>
    </TabBar>

</Shell>